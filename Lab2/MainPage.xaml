<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab2.MainPage"
             Title="Лаб 2: Запуск Excel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20" RowSpacing="12">

        <HorizontalStackLayout Grid.Row="0" Spacing="8" VerticalOptions="Center">
            <Label Text="Шлях до файлу:" VerticalOptions="Center" />
            <Entry x:Name="FilePathEntry" WidthRequest="500"
                   Placeholder="C:\path\to\file.xlsx" />
            <Button x:Name="BrowseButton" Text="Огляд..." Clicked="BrowseButton_Clicked" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" VerticalOptions="Center">
            <Button x:Name="OpenButton" Text="Відкрити в Excel" Clicked="OpenButton_Clicked" />
            <Button x:Name="ClearLogButton" Text="Очистити лог" Clicked="ClearLogButton_Clicked" />
            <Label x:Name="StatusLabel" Text="Активних процесів: 0"
                   VerticalOptions="Center" Margin="20,0,0,0" FontAttributes="Bold" />
        </HorizontalStackLayout>

        <Label Grid.Row="2" Text="Журнал подій:" FontAttributes="Bold" />

        <Border Grid.Row="3" Stroke="Gray" StrokeThickness="1" Padding="0">
            <ScrollView x:Name="LogScroll">
                <Label x:Name="LogLabel" FontFamily="Consolas" FontSize="13"
                       LineBreakMode="WordWrap" Padding="8" />
            </ScrollView>
        </Border>

    </Grid>

</ContentPage>
